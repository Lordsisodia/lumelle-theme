{% comment %}
  Lumelle PDP Reviews Carousel - Native Liquid
  Converted from React ReviewsAutoCarousel.tsx
  Pixel-perfect match with React styling
{% endcomment %}

<style>
  .pdp-reviews-section {
    font-family: 'Inter', system-ui, sans-serif;
  }
  .pdp-reviews-section .font-heading {
    font-family: 'Playfair Display', Georgia, serif;
  }
  .pdp-reviews-section .font-serif {
    font-family: 'Playfair Display', Georgia, serif;
  }
</style>

<section
  id="{{ section.settings.section_id | default: 'reviews' }}"
  class="pdp-reviews-section relative overflow-hidden bg-[#F8F5F2] py-12 md:py-14 lg:py-16"
  data-section-id="{{ section.id }}"
>
  {%- comment -%} Background Decorative Blobs {%- endcomment -%}
  <div aria-hidden="true" class="pointer-events-none absolute inset-0">
    <div class="absolute -top-28 left-1/2 h-[480px] w-[480px] -translate-x-1/2 rounded-full bg-[#FBC7B2]/25 blur-3xl"></div>
    <div class="absolute -bottom-32 right-[-120px] h-[520px] w-[520px] rounded-full bg-[#FDD4DC]/30 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-4 md:px-6">
    <div class="lg:grid lg:grid-cols-12 lg:items-center lg:gap-10">
      {%- comment -%} Desktop Heading Column {%- endcomment -%}
      <div class="lg:col-span-5">
        {%- comment -%} Mobile/Tablet Heading {%- endcomment -%}
        <div class="lg:hidden text-center mb-6">
          {% if section.settings.eyebrow != blank %}
            <span class="inline-flex rounded-full bg-[#FDD4DC]/40 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-[#1A1A1A]/70">
              {{ section.settings.eyebrow }}
          </span>
          {% endif %}
          {% if section.settings.title != blank %}
            <h2 class="font-heading mt-3 text-3xl font-bold text-[#1A1A1A] md:text-4xl">
              {{ section.settings.title }}
            </h2>
          {% endif %}
          {% if section.settings.description != blank %}
            <p class="mx-auto mt-3 max-w-md text-base leading-relaxed text-[#1A1A1A]/80 font-serif">
              {{ section.settings.description }}
            </p>
          {% endif %}
        </div>

        {%- comment -%} Desktop Heading {%- endcomment -%}
        <div class="hidden lg:flex lg:flex-col lg:items-start lg:gap-4 lg:text-left">
          {% if section.settings.eyebrow != blank %}
            <span class="inline-flex rounded-full bg-[#FDD4DC]/40 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-[#1A1A1A]/70">
              {{ section.settings.eyebrow }}
            </span>
          {% endif %}

          {% if section.settings.title != blank %}
            <h2 class="font-heading text-4xl font-bold text-[#1A1A1A] whitespace-pre-line">
              {{ section.settings.title }}
            </h2>
          {% endif %}

          {% if section.settings.description != blank %}
            <p class="max-w-md text-base leading-relaxed text-[#1A1A1A]/80 font-serif">
              {{ section.settings.description }}
            </p>
          {% endif %}

          {%- comment -%} Rating Summary {%- endcomment -%}
          <div class="mt-2 flex flex-wrap items-center gap-3 text-sm text-[#1A1A1A]/80">
            <span class="inline-flex items-center gap-2">
              <span class="pdp-stars">
                {%- for i in (1..5) -%}
                  <svg class="inline h-[18px] w-[18px] text-amber-400" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                {%- endfor -%}
              </span>
              <span class="font-semibold text-[#1A1A1A] text-base">{{ section.settings.rating_value | default: 4.9 }}</span>
            </span>

            {% if section.settings.review_count != blank %}
              <span class="inline-flex items-center rounded-full bg-white/75 px-4 py-1.5 font-semibold text-base ring-1 ring-[#FDD4DC]/50 backdrop-blur">
                {{ section.settings.review_count }} reviews
              </span>
            {% endif %}

            {% if section.settings.tagline != blank %}
              <span class="inline-flex items-center rounded-full bg-white/60 px-4 py-1.5 text-[#1A1A1A]/70 text-base ring-1 ring-[#FDD4DC]/40 backdrop-blur">
                {{ section.settings.tagline }}
              </span>
            {% endif %}
          </div>
        </div>
      </div>

      {%- comment -%} Reviews Carousel Column {%- endcomment -%}
      <div class="mt-4 md:mt-6 lg:col-span-7 lg:mt-0 lg:-mr-10">
        <div class="pdp-reviews-carousel overflow-x-auto snap-x snap-mandatory flex gap-4 pb-4 [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
          {%- for block in section.blocks -%}
            <article
              class="min-w-[min(85vw,340px)] snap-center flex-shrink-0 rounded-3xl border border-[#FBC7B2]/50 bg-white/95 p-5 shadow-[0_14px_32px_rgba(0,0,0,0.08)] backdrop-blur-sm transition-transform hover:-translate-y-1 hover:shadow-[0_20px_40px_rgba(0,0,0,0.12)]"
              {{ block.shopify_attributes }}
            >
              {%- comment -%} Review Header {%- endcomment -%}
              <div class="flex items-start gap-3">
                {% if section.settings.show_reviewer_photos and block.settings.reviewer_image %}
                  <img
                    src="{{ block.settings.reviewer_image | image_url: width: 80 }}"
                    alt="{{ block.settings.reviewer_name }}"
                    class="h-12 w-12 rounded-full border-2 border-white object-cover shadow-[0_4px_12px_rgba(0,0,0,0.1)]"
                    loading="lazy"
                  />
                {% elsif section.settings.show_reviewer_photos %}
                  <div class="h-12 w-12 rounded-full border-2 border-white bg-gradient-to-br from-[#FBC7B2] to-[#FDD4DC] flex items-center justify-center text-base font-bold text-[#55362A] shadow-[0_4px_12px_rgba(0,0,0,0.1)]">
                    {{ block.settings.reviewer_name | slice: 0 }}
                  </div>
                {% endif %}
                
                <div class="flex-1">
                  <div class="flex items-center justify-between">
                    <p class="font-semibold text-[#1A1A1A]">{{ block.settings.reviewer_name }}</p>
                    {% if block.settings.verified %}
                      <span class="inline-flex items-center gap-1 text-[10px] font-semibold uppercase tracking-[0.15em] text-green-700">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                          <polyline points="22 4 12 14.01 9 11.01"/>
                        </svg>
                        Verified
                      </span>
                    {% endif %}
                  </div>
                  
                  {%- comment -%} Star Rating {%- endcomment -%}
                  <div class="mt-1 flex items-center gap-1">
                    {%- assign stars = block.settings.stars | default: 5 -%}
                    {%- for i in (1..5) -%}
                      <svg class="h-4 w-4 {% if forloop.index <= stars %}text-amber-400{% else %}text-gray-300{% endif %}" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                    {%- endfor -%}
                  </div>
                </div>
              </div>

              {%- comment -%} Review Content {%- endcomment -%}
              <p class="mt-4 text-[15px] leading-relaxed text-[#1A1A1A]/90">
                "{{ block.settings.review_text }}"
              </p>

              {%- comment -%} Review Image {%- endcomment -%}
              {% if block.settings.review_image %}
                <div class="mt-4">
                  <img
                    src="{{ block.settings.review_image | image_url: width: 400 }}"
                    alt="Review photo"
                    class="h-24 w-auto rounded-xl object-cover"
                    loading="lazy"
                  />
                </div>
              {% endif %}

              {%- comment -%} Review Date {%- endcomment -%}
              {% if block.settings.review_date != blank %}
                <p class="mt-3 text-xs text-[#1A1A1A]/50">{{ block.settings.review_date }}</p>
              {% endif %}
            </article>
          {%- endfor -%}
        </div>

        {%- comment -%} Scroll Indicators {%- endcomment -%}
        <div class="mt-4 flex items-center justify-center gap-1.5">
          {%- for block in section.blocks -%}
            <button
              type="button"
              aria-label="Go to review {{ forloop.index }}"
              class="pdp-carousel-dot h-1.5 w-1.5 rounded-full transition-all {% if forloop.first %}bg-[#55362A] w-3{% else %}bg-[#55362A]/30{% endif %}"
              data-index="{{ forloop.index0 }}"
            ></button>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Simple carousel scroll sync for dots
  document.addEventListener('DOMContentLoaded', function() {
    const carousels = document.querySelectorAll('.pdp-reviews-carousel');
    carousels.forEach(carousel => {
      const dots = carousel.parentElement.querySelectorAll('.pdp-carousel-dot');
      const cards = carousel.querySelectorAll('article');
      
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const idx = Array.from(cards).indexOf(entry.target);
            dots.forEach((dot, i) => {
              if (i === idx) {
                dot.classList.add('bg-[#55362A]', 'w-3');
                dot.classList.remove('bg-[#55362A]/30');
              } else {
                dot.classList.remove('bg-[#55362A]', 'w-3');
                dot.classList.add('bg-[#55362A]/30');
              }
            });
          }
        });
      }, { threshold: 0.6, root: carousel });
      
      cards.forEach(card => observer.observe(card));
      
      // Click dots to scroll
      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          cards[i].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        });
      });
    });
  });
</script>

{% schema %}
{
  "name": "PDP Reviews Carousel",
  "tag": "section",
  "class": "pdp-reviews-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "default": "reviews"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Loved by thousands"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Customer Stories"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Real experiences from people who use it every day."
    },
    {
      "type": "range",
      "id": "rating_value",
      "label": "Overall Rating",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "default": 4.9
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review Count Display",
      "default": "2,847"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Summary Tagline"
    },
    {
      "type": "checkbox",
      "id": "show_reviewer_photos",
      "label": "Show Reviewer Photos",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer Name",
          "default": "Amelia"
        },
        {
          "type": "image_picker",
          "id": "reviewer_image",
          "label": "Reviewer Photo"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified Purchase",
          "default": true
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "Finally a towel that actually fits all my hair. Dries so much faster and my frizz is basically gone!"
        },
        {
          "type": "image_picker",
          "id": "review_image",
          "label": "Review Photo"
        },
        {
          "type": "text",
          "id": "review_date",
          "label": "Review Date",
          "default": "2 days ago"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP Reviews Carousel",
      "settings": {
        "eyebrow": "Loved by thousands",
        "title": "Customer Stories",
        "description": "Real experiences from people who use it every day.",
        "rating_value": 4.9,
        "review_count": "2,847"
      },
      "blocks": [
        {
          "type": "review",
          "settings": {
            "reviewer_name": "Amelia",
            "verified": true,
            "stars": 5,
            "review_text": "Finally a towel that actually fits all my hair. Dries so much faster and my frizz is basically gone!",
            "review_date": "2 days ago"
          }
        },
        {
          "type": "review",
          "settings": {
            "reviewer_name": "Keisha",
            "verified": true,
            "stars": 5,
            "review_text": "My silk press stayed fresh for a whole week! The waterproof lining is no joke. Best shower cap I've ever owned.",
            "review_date": "1 week ago"
          }
        },
        {
          "type": "review",
          "settings": {
            "reviewer_name": "Taylor",
            "verified": true,
            "stars": 5,
            "review_text": "Love that it's eco-friendly and reusable. The satin band is so soft, no more headaches or marks on my forehead.",
            "review_date": "3 days ago"
