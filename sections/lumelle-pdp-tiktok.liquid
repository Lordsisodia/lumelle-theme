{% comment %}
  Lumelle PDP TikTok Section - Native Liquid
  Converted from React FeaturedTikTok.tsx
  Pixel-perfect match with React styling
{% endcomment %}

<style>
  .pdp-tiktok-section {
    font-family: 'Inter', system-ui, sans-serif;
  }
  .pdp-tiktok-section .font-heading {
    font-family: 'Playfair Display', Georgia, serif;
  }
  
  /* Hide scrollbar but keep functionality */
  .pdp-tiktok-scroller {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .pdp-tiktok-scroller::-webkit-scrollbar {
    display: none;
  }
</style>

<section
  id="{{ section.settings.section_id }}"
  class="pdp-tiktok-section bg-white"
  data-section-id="{{ section.id }}"
>
  <div class="mx-auto max-w-6xl px-5 py-16 md:px-6">
    {%- comment -%} Section Heading {%- endcomment -%}
    <div class="{% if section.settings.alignment == 'center' %}text-center{% elsif section.settings.alignment == 'right' %}text-right{% else %}text-left{% endif %}">
      {% if section.settings.eyebrow != blank %}
        <span class="inline-flex rounded-full bg-[#FDD4DC]/40 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-[#1A1A1A]/70">
          {{ section.settings.eyebrow }}
        </span>
      {% endif %}
      {% if section.settings.title != blank %}
        <h2 class="font-heading mt-3 text-3xl font-bold text-[#1A1A1A] md:text-4xl">
          {{ section.settings.title }}
        </h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <p class="{% if section.settings.alignment == 'center' %}mx-auto{% endif %} mt-3 max-w-md text-base leading-relaxed text-[#1A1A1A]/80">
          {{ section.settings.description }}
        </p>
      {% endif %}
    </div>

    {%- comment -%} TikTok Carousel {%- endcomment -%}
    <div class="mt-6 rounded-3xl border border-[#FBC7B2]/40 bg-gradient-to-r from-[#FDEBE3] via-white to-[#FDEBE3] p-4 shadow-[0_4px_12px_rgba(0,0,0,0.08)]">
      <div
        class="pdp-tiktok-scroller relative flex snap-x snap-mandatory gap-3 overflow-x-auto px-1 pb-2 sm:px-2 lg:gap-4 lg:px-3 cursor-grab active:cursor-grabbing select-none"
        data-tiktok-scroller
      >
        {%- for block in section.blocks -%}
          <article
            class="min-w-[min(72vw,300px)] snap-center lg:min-w-[min(340px,26vw)]"
            data-tiktok-card
            {{ block.shopify_attributes }}
          >
            <div class="relative overflow-hidden rounded-2xl border border-[#FBC7B2]/40 pb-[158%] shadow-[0_4px_12px_rgba(0,0,0,0.08)] bg-black">
              <iframe
                src="{{ block.settings.embed_url }}{% unless block.settings.embed_url contains 'lang=' %}&lang=en{% endunless %}"
                title="{{ block.settings.creator_name }} TikTok embed"
                loading="lazy"
                allow="encrypted-media; fullscreen; clipboard-write"
                sandbox="allow-scripts allow-same-origin allow-presentation"
                allowfullscreen
                scrolling="no"
                class="absolute inset-0 h-full w-full"
                style="border: 0;"
              ></iframe>
            </div>
            <div class="mt-2 text-center text-sm text-[#1A1A1A]/70">
              {{ block.settings.creator_name }} • {{ block.settings.creator_handle }}
            </div>
            <div class="mt-1 text-center">
              <a
                href="{{ block.settings.video_url }}"
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center gap-2 rounded-full border border-[#FDD4DC]/60 px-3 py-1 text-xs font-semibold text-[#1A1A1A]/80 hover:bg-[#FDD4DC]/40 transition-colors"
              >
                Watch on TikTok
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 17L17 7"/>
                  <path d="M7 7h10v10"/>
                </svg>
              </a>
            </div>
          </article>
        {%- endfor -%}

        {%- comment -%} Navigation Arrows (Desktop only) {%- endcomment -%}
        <div class="pointer-events-none absolute inset-y-0 left-0 hidden items-center md:flex">
          <button
            type="button"
            aria-label="Scroll videos left"
            class="pointer-events-auto ml-1 inline-flex h-9 w-9 items-center justify-center rounded-full border border-[#FDD4DC]/60 bg-white text-[#1A1A1A] shadow-[0_4px_12px_rgba(0,0,0,0.08)] hover:bg-[#FDD4DC]/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#55362A] transition-colors"
            data-tiktok-prev
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 18l-6-6 6-6"/>
            </svg>
          </button>
        </div>
        <div class="pointer-events-none absolute inset-y-0 right-0 hidden items-center md:flex">
          <button
            type="button"
            aria-label="Scroll videos right"
            class="pointer-events-auto mr-1 inline-flex h-9 w-9 items-center justify-center rounded-full border border-[#FDD4DC]/60 bg-white text-[#1A1A1A] shadow-[0_4px_12px_rgba(0,0,0,0.08)] hover:bg-[#FDD4DC]/40 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#55362A] transition-colors"
            data-tiktok-next
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    {%- comment -%} Pagination Dots {%- endcomment -%}
    <div class="mt-4 flex items-center justify-center gap-1.5 text-sm text-[#1A1A1A]/80" data-tiktok-dots>
      {%- for block in section.blocks -%}
        <button
          type="button"
          aria-label="Go to TikTok slide {{ forloop.index }}"
          class="h-0.5 w-0.5 rounded-full transition-all {% if forloop.first %}bg-[#55362A]{% else %}bg-[#55362A]/30{% endif %}"
          data-dot-index="{{ forloop.index0 }}"
        ></button>
      {%- endfor -%}
    </div>
    <span class="sr-only" aria-live="polite" data-tiktok-sr>
      Showing TikTok slide 1 of {{ section.blocks.size }}
    </span>
  </div>
</section>

<script>
  (function() {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;
    
    const scroller = section.querySelector('[data-tiktok-scroller]');
    const cards = section.querySelectorAll('[data-tiktok-card]');
    const dots = section.querySelectorAll('[data-dot-index]');
    const prevBtn = section.querySelector('[data-tiktok-prev]');
    const nextBtn = section.querySelector('[data-tiktok-next]');
    const srAnnounce = section.querySelector('[data-tiktok-sr]');
    
    let activeIndex = 0;
    
    // Drag to scroll functionality
    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;
    
    scroller.addEventListener('mousedown', (e) => {
      isDown = true;
      startX = e.pageX - scroller.offsetLeft;
      scrollLeft = scroller.scrollLeft;
    });
    
    scroller.addEventListener('mouseleave', () => {
      isDown = false;
    });
    
    scroller.addEventListener('mouseup', () => {
      isDown = false;
    });
    
    scroller.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - scroller.offsetLeft;
      const walk = x - startX;
      scroller.scrollLeft = scrollLeft - walk;
    });
    
    // Scroll to specific card
    function goTo(index, behavior = 'smooth') {
      if (!cards.length) return;
      
      const target = ((index % cards.length) + cards.length) % cards.length;
      const card = cards[target];
      const offset = card.offsetLeft - (scroller.clientWidth - card.offsetWidth) / 2;
      scroller.scrollTo({ left: Math.max(0, offset), behavior });
      
      activeIndex = target;
      updateDots();
    }
    
    // Update dot indicators
    function updateDots() {
      dots.forEach((dot, i) => {
        if (i === activeIndex) {
          dot.classList.remove('bg-[#55362A]/30');
          dot.classList.add('bg-[#55362A]');
        } else {
          dot.classList.remove('bg-[#55362A]');
          dot.classList.add('bg-[#55362A]/30');
        }
      });
      
      if (srAnnounce) {
        srAnnounce.textContent = `Showing TikTok slide ${activeIndex + 1} of ${cards.length}`;
      }
    }
    
    // Detect active card on scroll
    const scrollObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const idx = Array.from(cards).indexOf(entry.target);
          if (idx !== -1 && idx !== activeIndex) {
            activeIndex = idx;
            updateDots();
          }
        }
      });
    }, { threshold: 0.6, root: scroller });
    
    cards.forEach(card => scrollObserver.observe(card));
    
    // Navigation buttons
    if (prevBtn) {
      prevBtn.addEventListener('click', () => goTo(activeIndex - 1));
    }
    if (nextBtn) {
      nextBtn.addEventListener('click', () => goTo(activeIndex + 1));
    }
    
    // Dot navigation
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => goTo(i));
    });
  })();
</script>

{% schema %}
{
  "name": "PDP TikTok Section",
  "tag": "section",
  "class": "pdp-tiktok-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID (for anchor links)"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "As seen on TikTok"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Creators using Lumelle"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Swipe to watch a few of our favourite videos."
    }
  ],
  "blocks": [
    {
      "type": "tiktok",
      "name": "TikTok Video",
      "settings": [
        {
          "type": "text",
          "id": "creator_name",
          "label": "Creator Name",
          "default": "Sarah"
        },
        {
          "type": "text",
          "id": "creator_handle",
          "label": "Creator Handle",
          "default": "@sarahstyles"
        },
        {
          "type": "text",
          "id": "embed_url",
          "label": "TikTok Embed URL",
          "info": "Get embed URL from TikTok 'Share' > 'Embed' option"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Direct Video URL",
          "default": "https://www.tiktok.com/"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP TikTok Section",
      "settings": {
        "eyebrow": "As seen on TikTok",
        "title": "Creators using Lumelle",
        "description": "Swipe to watch a few of our favourite videos."
      },
      "blocks": [
        {
          "type": "tiktok",
          "settings": {
            "creator_name": "Keisha",
            "creator_handle": "@keishab",
            "embed_url": "https://www.tiktok.com/embed/v2/1234567890",
            "video_url": "https://www.tiktok.com/@keishab/video/1234567890"
          }
        },
        {
          "type": "tiktok",
          "settings": {
            "creator_name": "Taylor",
            "creator_handle": "@taylorbeauty",
            "embed_url": "https://www.tiktok.com/embed/v2/0987654321",
            "video_url": "https://www.tiktok.com/@taylorbeauty/video/0987654321"
          }
        },
        {
          "type": "tiktok",
          "settings": {
            "creator_name": "Aria",
            "creator_handle": "@ariastyles",
            "embed_url": "https://www.tiktok.com/embed/v2/1122334455",
            "video_url": "https://www.tiktok.com/@ariastyles/video/1122334455"
          }
        }
      ]
    }
  ]
}
{% endschema %}
