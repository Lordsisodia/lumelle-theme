{% comment %}
  Lumelle Email Capture Section
  Native Liquid implementation converted from React EmailCaptureBand.tsx
  Pixel-perfect styling with Tailwind classes
{% endcomment %}

<style>
  /* Custom animations for email capture */
  @keyframes email-success-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.02); }
  }
  
  .email-capture-success-badge {
    animation: email-success-pulse 2s ease-in-out infinite;
  }
  
  /* Gradient text support */
  .gradient-text-cocoa-cta {
    background: linear-gradient(to right, #55362A, #FBC7B2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>

<section 
  class="relative overflow-hidden py-16 md:py-20"
  style="background: linear-gradient(135deg, rgba(250, 236, 229, 0.3) 0%, rgba(250, 236, 229, 0.4) 50%, rgba(107, 76, 59, 0.2) 100%);"
>
  {%- comment -%} Background decoration {%- endcomment -%}
  <div class="absolute inset-0 opacity-10 pointer-events-none">
    <div 
      class="absolute top-0 left-1/4 w-96 h-96 rounded-full blur-3xl"
      style="background: rgba(168, 187, 164, 0.3);"
    ></div>
    <div 
      class="absolute bottom-0 right-1/4 w-96 h-96 rounded-full blur-3xl"
      style="background: rgba(107, 76, 59, 0.2);"
    ></div>
  </div>

  <div class="relative mx-auto max-w-3xl px-4 md:px-6">
    {%- comment -%} Main Card {%- endcomment -%}
    <div 
      class="rounded-3xl p-8 md:p-12 shadow-2xl"
      style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25), inset 0 0 0 1px rgba(250, 236, 229, 0.3);"
    >
      <div class="flex flex-col items-center gap-6 text-center">
        
        {%- comment -%} Icon Container {%- endcomment -%}
        <div 
          id="email-capture-icon-{{ section.id }}"
          class="flex h-16 w-16 items-center justify-center rounded-2xl shadow-lg"
          style="background: linear-gradient(135deg, rgba(168, 187, 164, 0.2) 0%, rgba(107, 76, 59, 0.2) 100%); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), inset 0 0 0 1px rgba(168, 187, 164, 0.3);"
        >
          {%- comment -%} Default: Gift icon (shown before success) {%- endcomment -%}
          <span id="gift-icon-{{ section.id }}" class="block">
            <svg class="h-8 w-8" style="color: #55362A;" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 1 0 9.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1 1 14.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />
            </svg>
          </span>
          {%- comment -%} Success: PartyPopper icon (hidden initially) {%- endcomment -%}
          <span id="party-icon-{{ section.id }}" class="hidden">
            <svg class="h-8 w-8" style="color: #55362A;" fill="none" stroke="currentColor" stroke-width: 1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.87c1.355 0 2.697.055 4.024.165C17.155 8.51 18 9.473 18 10.608v2.513m-3-4.87v-1.5m-6 1.5v-1.5m12 9.75-1.5.75a3.354 3.354 0 0 1-3 0 3.354 3.354 0 0 0-3 0 3.354 3.354 0 0 1-3 0 3.354 3.354 0 0 0-3 0 3.354 3.354 0 0 1-3 0L3 16.5m15-3.38a48.474 48.474 0 0 0-6-.37c-2.032 0-4.034.125-6 .37m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.17c0 .62-.504 1.124-1.125 1.124H4.125A1.125 1.125 0 0 1 3 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 0 1 6 13.12" />
            </svg>
          </span>
        </div>

        {%- comment -%} Heading (shown before success) {%- endcomment -%}
        <div id="email-capture-heading-{{ section.id }}" class="space-y-2">
          <h3 class="text-3xl md:text-4xl font-bold" style="font-family: var(--font-heading-family, inherit); color: #55362A;">
            Get <span class="gradient-text-cocoa-cta">{{ section.settings.discount_percent }}% off</span> {{ section.settings.heading_suffix }}
          </h3>
          <p class="text-base" style="color: rgba(85, 54, 42, 0.7);">
            {{ section.settings.subheading }}
          </p>
        </div>

        {%- comment -%} Success Heading (hidden initially) {%- endcomment -%}
        <div id="email-capture-success-heading-{{ section.id }}" class="space-y-2 hidden">
          <h3 class="text-3xl md:text-4xl font-bold" style="font-family: var(--font-heading-family, inherit); color: #55362A;">
            {{ section.settings.success_heading }}
          </h3>
          <p class="text-lg" style="color: rgba(85, 54, 42, 0.8);">
            {{ section.settings.success_subheading }}
          </p>
        </div>

        {%- comment -%} Form Section (shown before success) {%- endcomment -%}
        <div id="email-capture-form-container-{{ section.id }}" class="w-full max-w-md">
          {% form 'customer', id: 'email-capture-form-' | append: section.id, class: 'space-y-4' %}
            <input type="hidden" name="contact[tags]" value="newsletter,landing-page">
            <input type="hidden" name="contact[source]" value="email-capture-band">
            
            <div class="relative">
              {%- comment -%} Mail Icon {%- endcomment -%}
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <svg class="h-5 w-5" style="color: rgba(28, 25, 23, 0.4);" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
              </div>
              
              <input
                type="email"
                name="contact[email]"
                id="email-input-{{ section.id }}"
                required
                autocomplete="email"
                placeholder="{{ section.settings.email_placeholder }}"
                class="w-full rounded-2xl border-2 bg-white py-4 pl-12 pr-4 text-sm outline-none transition-all focus:ring-4 disabled:cursor-not-allowed disabled:opacity-70"
                style="border-color: rgba(250, 236, 229, 0.4); --tw-ring-color: rgba(168, 187, 164, 0.1);"
                onfocus="this.style.borderColor='rgba(168, 187, 164, 0.6)'; this.style.setProperty('--tw-ring-color', 'rgba(168, 187, 164, 0.1)';"
                onblur="this.style.borderColor='rgba(250, 236, 229, 0.4)';"
              >
            </div>

            {%- comment -%} Error message container {%- endcomment -%}
            <p id="email-error-{{ section.id }}" class="text-sm text-red-600 hidden" aria-live="polite"></p>

            <button
              type="submit"
              id="submit-btn-{{ section.id }}"
              class="group relative w-full overflow-hidden rounded-2xl px-8 py-4 text-base font-semibold text-white shadow-lg transition-all hover:-translate-y-0.5 hover:shadow-xl active:translate-y-0 disabled:cursor-not-allowed disabled:opacity-70"
              style="background: linear-gradient(to right, #55362A 0%, rgba(85, 54, 42, 0.9) 100%); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);"
            >
              <span class="relative flex items-center justify-center gap-2">
                <span id="btn-text-{{ section.id }}">{{ section.settings.button_text }}</span>
                <svg id="btn-icon-{{ section.id }}" class="h-5 w-5 transition-transform group-hover:scale-110" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 1 0 9.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1 1 14.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />
                </svg>
              </span>
            </button>
          {% endform %}
        </div>

        {%- comment -%} Success Section (hidden initially) {%- endcomment -%}
        <div id="email-capture-success-container-{{ section.id }}" class="w-full max-w-md space-y-4 hidden">
          {%- comment -%} Discount Badge {%- endcomment -%}
          <div 
            onclick="navigator.clipboard.writeText('{{ section.settings.discount_code }}').then(() => { const el = document.getElementById('copy-feedback-{{ section.id }}'); el.textContent = 'Copied!'; setTimeout(() => el.textContent = 'Tap to copy', 2000); })"
            class="email-capture-success-badge group relative cursor-pointer rounded-2xl p-6 transition-all hover:shadow-lg active:scale-[0.98]"
            style="border: 2px dashed rgba(168, 187, 164, 0.4); background: linear-gradient(135deg, rgba(250, 236, 229, 0.3) 0%, rgba(168, 187, 164, 0.1) 100%);"
            onmouseover="this.style.borderColor='rgba(168, 187, 164, 0.6)'; this.style.boxShadow='0 10px 15px -3px rgba(0, 0, 0, 0.1)';"
            onmouseout="this.style.borderColor='rgba(168, 187, 164, 0.4)'; this.style.boxShadow='none';"
          >
            <div class="flex items-center justify-center gap-3">
              <span class="text-xs font-semibold uppercase tracking-[0.3em]" style="color: rgba(28, 25, 23, 0.6);">Your code</span>
            </div>
            <div class="mt-3 flex items-center justify-center gap-2">
              <span class="text-2xl font-bold tracking-wider" style="font-family: var(--font-heading-family, inherit); color: #55362A;">
                ✨ {{ section.settings.discount_code }} ✨
              </span>
            </div>
            <div class="mt-3 flex items-center justify-center gap-2 text-sm font-semibold" style="color: #FBC7B2;">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75" />
              </svg>
              <span id="copy-feedback-{{ section.id }}">Tap to copy</span>
            </div>
          </div>

          <p class="text-sm" style="color: rgba(28, 25, 23, 0.8);">
            {{ section.settings.discount_instruction }}
          </p>
        </div>

        {%- comment -%} Trust Badge {%- endcomment -%}
        <div class="flex items-center gap-2 text-xs" style="color: rgba(28, 25, 23, 0.6);">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
          </svg>
          <span>{{ section.settings.trust_text }}</span>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const storageKey = 'lumelle_email_capture';
  
  // Check if already subscribed
  if (localStorage.getItem(storageKey)) {
    showSuccessState();
  }
  
  // Form submission handler
  const form = document.getElementById('email-capture-form-' + sectionId);
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      
      const emailInput = document.getElementById('email-input-' + sectionId);
      const submitBtn = document.getElementById('submit-btn-' + sectionId);
      const btnText = document.getElementById('btn-text-' + sectionId);
      const btnIcon = document.getElementById('btn-icon-' + sectionId);
      const errorEl = document.getElementById('email-error-' + sectionId);
      const email = emailInput.value.trim();
      
      if (!email) return;
      
      // Show loading state
      submitBtn.disabled = true;
      btnText.textContent = '{{ section.settings.loading_text }}';
      btnIcon.style.display = 'none';
      errorEl.classList.add('hidden');
      
      // Submit to Shopify
      const formData = new FormData(form);
      
      fetch('/contact', {
        method: 'POST',
        body: formData
      })
      .then(response => {
        if (response.ok) {
          localStorage.setItem(storageKey, '1');
          showSuccessState();
        } else {
          throw new Error('Subscription failed');
        }
      })
      .catch(error => {
        errorEl.textContent = '{{ section.settings.error_text }}';
        errorEl.classList.remove('hidden');
        submitBtn.disabled = false;
        btnText.textContent = '{{ section.settings.button_text }}';
        btnIcon.style.display = 'block';
      });
    });
  }
  
  function showSuccessState() {
    // Hide form elements
    document.getElementById('email-capture-form-container-' + sectionId).classList.add('hidden');
    document.getElementById('email-capture-heading-' + sectionId).classList.add('hidden');
    document.getElementById('gift-icon-' + sectionId).classList.add('hidden');
    
    // Show success elements
    document.getElementById('email-capture-success-container-' + sectionId).classList.remove('hidden');
    document.getElementById('email-capture-success-heading-' + sectionId).classList.remove('hidden');
    document.getElementById('party-icon-' + sectionId).classList.remove('hidden');
  }
})();
</script>

{% schema %}
{
  "name": "Lumelle Email Capture",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "range",
      "id": "discount_percent",
      "label": "Discount Percentage",
      "min": 5,
      "max": 50,
      "step": 5,
      "default": 10,
      "unit": "%"
    },
    {
      "type": "text",
      "id": "heading_suffix",
      "label": "Heading Suffix",
      "default": "your first order"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Join for exclusive creator tutorials, drops, and early access."
    },
    {
      "type": "header",
      "content": "Form Settings"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email Input Placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Unlock Your 10% Off"
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "Loading State Text",
      "default": "Unlocking your discount…"
    },
    {
      "type": "text",
      "id": "error_text",
      "label": "Error Message",
      "default": "Couldn't subscribe right now. Please try again."
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust Badge Text",
      "default": "Secure signup. No spam, unsubscribe anytime."
    },
    {
      "type": "header",
      "content": "Success State Settings"
    },
    {
      "type": "text",
      "id": "success_heading",
      "label": "Success Heading",
      "default": "You're in! 🎉"
    },
    {
      "type": "text",
      "id": "success_subheading",
      "label": "Success Subheading",
      "default": "Welcome to the family"
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Discount Code",
      "default": "LUMELLE10"
    },
    {
      "type": "text",
      "id": "discount_instruction",
      "label": "Discount Instruction",
      "default": "Use at checkout for 10% off your first order."
    }
  ],
  "presets": [
    {
      "name": "Lumelle Email Capture"
    }
  ]
}
{% endschema %}
