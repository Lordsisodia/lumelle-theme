{%- comment -%}
  Lumelle Bundle Cards Section
  Pixel-perfect conversion from React BundleCards.tsx
  @source /original-app/src/domains/client/marketing/ui/sections/shop/bundle-cards/BundleCards.tsx
{%- endcomment -%}

{%- style -%}
  .bundle-cards-section {
    background-color: #FFFFFF;
    padding-top: 3.5rem;
    padding-bottom: 3.5rem;
  }

  @media (min-width: 768px) {
    .bundle-cards-section {
      padding-top: 4rem;
      padding-bottom: 4rem;
    }
  }

  .bundle-cards-container {
    max-width: 72rem;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1rem;
    padding-right: 1rem;
  }

  @media (min-width: 768px) {
    .bundle-cards-container {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }

  /* Section Heading Styles */
  .bundle-heading-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    text-align: center;
    color: #55362A;
  }

  .bundle-eyebrow {
    display: inline-flex;
    border-radius: 9999px;
    background-color: rgba(253, 212, 220, 0.4);
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: rgba(85, 54, 42, 0.7);
  }

  .bundle-heading-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
    width: 100%;
  }

  .bundle-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.875rem;
    font-weight: 700;
    line-height: 1.2;
    white-space: pre-line;
    margin: 0;
  }

  @media (min-width: 768px) {
    .bundle-title {
      font-size: 2.25rem;
    }
  }

  .bundle-description {
    max-width: 42rem;
    font-size: 1rem;
    line-height: 1.625;
    color: rgba(85, 54, 42, 0.8);
    font-family: 'Playfair Display', serif;
    margin: 0;
  }

  /* Cards Grid */
  .bundle-cards-grid {
    margin-top: 2.5rem;
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .bundle-cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Individual Card */
  .bundle-card {
    overflow: hidden;
    border-radius: 2.5rem;
    border: 1px solid rgba(253, 212, 220, 0.6);
    background-color: #FFFFFF;
    box-shadow: 0 20px 60px rgba(251, 199, 178, 0.35);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .bundle-card:hover {
    transform: translateY(-2px);
  }

  .bundle-card--active {
    border-color: rgba(85, 54, 42, 0.6);
  }

  /* Card Image Container */
  .bundle-card-image-wrapper {
    position: relative;
    aspect-ratio: 1 / 1;
    background-color: rgba(253, 212, 220, 0.15);
  }

  @media (min-width: 768px) {
    .bundle-card-image-wrapper {
      aspect-ratio: auto;
      height: 20rem;
    }
  }

  @media (min-width: 1024px) {
    .bundle-card-image-wrapper {
      height: 21rem;
    }
  }

  .bundle-card-image {
    height: 100%;
    width: 100%;
    object-fit: contain;
    padding: 1.5rem;
  }

  @media (min-width: 768px) {
    .bundle-card-image {
      padding: 2rem;
    }
  }

  /* Price Badge */
  .bundle-price-badge {
    position: absolute;
    left: 1.25rem;
    top: 1.25rem;
    border-radius: 9999px;
    background-color: rgba(255, 255, 255, 0.85);
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: #55362A;
    box-shadow: 0 20px 60px rgba(251, 199, 178, 0.35);
    backdrop-filter: blur(8px);
  }

  /* Card Content */
  .bundle-card-content {
    padding: 1.5rem;
  }

  .bundle-card-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .bundle-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.25;
    color: #55362A;
    margin: 0;
  }

  .bundle-card-subtitle {
    font-size: 0.875rem;
    color: rgba(85, 54, 42, 0.75);
    margin: 0;
    line-height: 1.5;
  }

  /* Chips */
  .bundle-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .bundle-chip {
    display: inline-flex;
    border-radius: 9999px;
    border: 1px solid rgba(253, 212, 220, 0.6);
    background-color: #FFFFFF;
    padding: 0.25rem 0.75rem;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(85, 54, 42, 0.7);
  }

  /* CTA Buttons */
  .bundle-cta-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .bundle-cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background-color: #55362A;
    padding: 0.75rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #FFFFFF;
    text-decoration: none;
    box-shadow: 0 20px 60px rgba(251, 199, 178, 0.35);
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .bundle-cta-primary:hover {
    transform: translateY(-2px);
    background-color: #3D2820;
  }

  .bundle-cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    border: 1px solid rgba(253, 212, 220, 0.6);
    background-color: #FFFFFF;
    padding: 0.75rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #55362A;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .bundle-cta-secondary:hover {
    background-color: rgba(247, 239, 232, 0.6);
  }
{%- endstyle -%}

<section class="bundle-cards-section">
  <div class="bundle-cards-container">
    {%- comment -%} Section Heading {%- endcomment -%}
    <div class="bundle-heading-wrapper">
      {%- if section.settings.eyebrow != blank -%}
        <span class="bundle-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      
      <div class="bundle-heading-content">
        <h2 class="bundle-title">{{ section.settings.title }}</h2>
        {%- if section.settings.description != blank -%}
          <p class="bundle-description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Bundle Cards Grid {%- endcomment -%}
    <div class="bundle-cards-grid">
      {%- comment -%} Card 1 {%- endcomment -%}
      {%- assign product1 = section.settings.product1 -%}
      {%- if product1 != blank -%}
        <article class="bundle-card{% if section.settings.active_card == 'product1' %} bundle-card--active{% endif %}">
          <div class="bundle-card-image-wrapper">
            {%- if product1.featured_image -%}
              <img
                src="{{ product1.featured_image | image_url: width: 600 }}"
                alt="{{ product1.featured_image.alt | default: product1.title | escape }}"
                class="bundle-card-image"
                loading="lazy"
                decoding="async"
                width="600"
                height="600"
              >
            {%- endif -%}
            {%- if section.settings.product1_show_price and product1.price > 0 -%}
              <div class="bundle-price-badge">
                From {{ product1.price | money_without_trailing_zeros }}
              </div>
            {%- endif -%}
          </div>
          
          <div class="bundle-card-content">
            <div class="bundle-card-header">
              <h3 class="bundle-card-title">{{ product1.title }}</h3>
              {%- if section.settings.product1_subtitle != blank -%}
                <p class="bundle-card-subtitle">{{ section.settings.product1_subtitle }}</p>
              {%- elsif product1.description != blank -%}
                <p class="bundle-card-subtitle">{{ product1.description | strip_html | truncatewords: 20 }}</p>
              {%- endif -%}
            </div>
            
            {%- if section.settings.product1_chip1 != blank or section.settings.product1_chip2 != blank or section.settings.product1_chip3 != blank -%}
              <div class="bundle-chips">
                {%- if section.settings.product1_chip1 != blank -%}
                  <span class="bundle-chip">{{ section.settings.product1_chip1 }}</span>
                {%- endif -%}
                {%- if section.settings.product1_chip2 != blank -%}
                  <span class="bundle-chip">{{ section.settings.product1_chip2 }}</span>
                {%- endif -%}
                {%- if section.settings.product1_chip3 != blank -%}
                  <span class="bundle-chip">{{ section.settings.product1_chip3 }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}
            
            <div class="bundle-cta-wrapper">
              <a href="{{ product1.url }}" class="bundle-cta-primary">
                {{ section.settings.shop_now_text }}
              </a>
              <a href="{{ product1.url }}" class="bundle-cta-secondary">
                {{ section.settings.details_text }}
              </a>
            </div>
          </div>
        </article>
      {%- endif -%}

      {%- comment -%} Card 2 {%- endcomment -%}
      {%- assign product2 = section.settings.product2 -%}
      {%- if product2 != blank -%}
        <article class="bundle-card{% if section.settings.active_card == 'product2' %} bundle-card--active{% endif %}">
          <div class="bundle-card-image-wrapper">
            {%- if product2.featured_image -%}
              <img
                src="{{ product2.featured_image | image_url: width: 600 }}"
                alt="{{ product2.featured_image.alt | default: product2.title | escape }}"
                class="bundle-card-image"
                loading="lazy"
                decoding="async"
                width="600"
                height="600"
              >
            {%- endif -%}
            {%- if section.settings.product2_show_price and product2.price > 0 -%}
              <div class="bundle-price-badge">
                From {{ product2.price | money_without_trailing_zeros }}
              </div>
            {%- endif -%}
          </div>
          
          <div class="bundle-card-content">
            <div class="bundle-card-header">
              <h3 class="bundle-card-title">{{ product2.title }}</h3>
              {%- if section.settings.product2_subtitle != blank -%}
                <p class="bundle-card-subtitle">{{ section.settings.product2_subtitle }}</p>
              {%- elsif product2.description != blank -%}
                <p class="bundle-card-subtitle">{{ product2.description | strip_html | truncatewords: 20 }}</p>
              {%- endif -%}
            </div>
            
            {%- if section.settings.product2_chip1 != blank or section.settings.product2_chip2 != blank or section.settings.product2_chip3 != blank -%}
              <div class="bundle-chips">
                {%- if section.settings.product2_chip1 != blank -%}
                  <span class="bundle-chip">{{ section.settings.product2_chip1 }}</span>
                {%- endif -%}
                {%- if section.settings.product2_chip2 != blank -%}
                  <span class="bundle-chip">{{ section.settings.product2_chip2 }}</span>
                {%- endif -%}
                {%- if section.settings.product2_chip3 != blank -%}
                  <span class="bundle-chip">{{ section.settings.product2_chip3 }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}
            
            <div class="bundle-cta-wrapper">
              <a href="{{ product2.url }}" class="bundle-cta-primary">
                {{ section.settings.shop_now_text }}
              </a>
              <a href="{{ product2.url }}" class="bundle-cta-secondary">
                {{ section.settings.details_text }}
              </a>
            </div>
          </div>
        </article>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lumelle Bundle Cards",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Shop the sets"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Build your routine"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Two creator-loved essentials. Start with the cap, add the heatless curler, and keep every shower + style day flawless."
    },
    {
      "type": "header",
      "content": "Button Text"
    },
    {
      "type": "text",
      "id": "shop_now_text",
      "label": "Shop now button text",
      "default": "Shop now"
    },
    {
      "type": "text",
      "id": "details_text",
      "label": "Details button text",
      "default": "Details"
    },
    {
      "type": "select",
      "id": "active_card",
      "label": "Active/Selected Card",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "product1", "label": "Product 1" },
        { "value": "product2", "label": "Product 2" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Product 1"
    },
    {
      "type": "product",
      "id": "product1",
      "label": "Product 1"
    },
    {
      "type": "text",
      "id": "product1_subtitle",
      "label": "Product 1 Subtitle",
      "info": "Override the product description. Leave blank to use the default product description."
    },
    {
      "type": "checkbox",
      "id": "product1_show_price",
      "label": "Show price badge",
      "default": true
    },
    {
      "type": "text",
      "id": "product1_chip1",
      "label": "Product 1 Chip 1",
      "default": "Waterproof satin"
    },
    {
      "type": "text",
      "id": "product1_chip2",
      "label": "Product 1 Chip 2",
      "default": "30-day returns"
    },
    {
      "type": "text",
      "id": "product1_chip3",
      "label": "Product 1 Chip 3"
    },
    {
      "type": "header",
      "content": "Product 2"
    },
    {
      "type": "product",
      "id": "product2",
      "label": "Product 2"
    },
    {
      "type": "text",
      "id": "product2_subtitle",
      "label": "Product 2 Subtitle",
      "info": "Override the product description. Leave blank to use the default product description."
    },
    {
      "type": "checkbox",
      "id": "product2_show_price",
      "label": "Show price badge",
      "default": true
    },
    {
      "type": "text",
      "id": "product2_chip1",
      "label": "Product 2 Chip 1",
      "default": "Heatless curls"
    },
    {
      "type": "text",
      "id": "product2_chip2",
      "label": "Product 2 Chip 2",
      "default": "30-day returns"
    },
    {
      "type": "text",
      "id": "product2_chip3",
      "label": "Product 2 Chip 3"
    }
  ],
  "presets": [
    {
      "name": "Lumelle Bundle Cards"
    }
  ]
}
{% endschema %}
