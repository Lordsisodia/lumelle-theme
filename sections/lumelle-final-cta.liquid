{% comment %}
  Lumelle Final CTA Section
  Converted from React FinalCtaSection + SpinWheelLocal
  Pixel-perfect recreation with simplified static wheel design
{% endcomment %}

<style>
  .lumelle-final-cta {
    background-color: #ffffff;
    padding: 4rem 1rem;
  }
  
  @media (min-width: 768px) {
    .lumelle-final-cta {
      padding: 4rem 1.5rem;
    }
  }
  
  .lumelle-final-cta__card {
    max-width: 64rem;
    margin: 0 auto;
    border-radius: 3rem;
    border: 1px solid rgba(251, 199, 178, 0.4);
    background: linear-gradient(
      to bottom right,
      rgba(251, 199, 178, 0.35) 0%,
      rgba(253, 212, 220, 0.25) 50%,
      rgba(251, 199, 178, 0.20) 100%
    );
    padding: 2rem;
    text-align: center;
    box-shadow: 0 25px 80px rgba(249, 165, 138, 0.35);
  }
  
  @media (min-width: 768px) {
    .lumelle-final-cta__card {
      padding: 3rem;
    }
  }
  
  .lumelle-final-cta__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }
  
  @media (min-width: 768px) {
    .lumelle-final-cta__content {
      gap: 2.5rem;
    }
  }
  
  .lumelle-final-cta__heading {
    font-family: 'Playfair Display', serif;
    font-size: 1.875rem;
    font-weight: 700;
    line-height: 1.25;
    color: #55362A;
    max-width: 48rem;
    text-align: center;
    margin: 0;
  }
  
  @media (min-width: 768px) {
    .lumelle-final-cta__heading {
      font-size: 2.25rem;
    }
  }
  
  /* Static Wheel Container */
  .lumelle-final-cta__wheel-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: #55362A;
  }
  
  /* Wheel wrapper */
  .lumelle-final-cta__wheel {
    position: relative;
    height: 16rem;
    width: 16rem;
    max-width: 100%;
  }
  
  @media (min-width: 768px) {
    .lumelle-final-cta__wheel {
      height: 18rem;
      width: 18rem;
    }
  }
  
  /* Wheel pointer */
  .lumelle-final-cta__wheel-pointer {
    position: absolute;
    left: 50%;
    top: -10px;
    z-index: 20;
    transform: translateX(-50%);
  }
  
  .lumelle-final-cta__wheel-pointer::before {
    content: '';
    display: block;
    height: 1rem;
    width: 1rem;
    transform: rotate(45deg);
    border-radius: 2px;
    background-color: #55362A;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
  }
  
  /* Wheel body */
  .lumelle-final-cta__wheel-body {
    position: absolute;
    inset: 0;
  }
  
  .lumelle-final-cta__wheel-inner {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 8px solid #ffffff;
    box-shadow: 0 18px 38px rgba(0, 0, 0, 0.12);
    /* Conic gradient for wheel segments */
    background: conic-gradient(
      #F9A58A 0deg 45deg,
      #F4C7B7 45deg 90deg,
      #FDD9C3 90deg 135deg,
      #F7B8A0 135deg 180deg,
      #F9A58A 180deg 225deg,
      #F7B8A0 225deg 270deg,
      #FDD9C3 270deg 315deg,
      #F7B8A0 315deg 360deg
    );
  }
  
  /* Wheel labels */
  .lumelle-final-cta__wheel-labels {
    position: absolute;
    inset: 0;
    user-select: none;
  }
  
  .lumelle-final-cta__wheel-label {
    position: absolute;
    transform: translate(-50%, -50%);
    border-radius: 9999px;
    background-color: rgba(255, 255, 255, 0.85);
    padding: 0.25rem 0.5rem;
    font-size: 11px;
    font-weight: 600;
    color: #55362A;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
    backdrop-filter: blur(4px);
  }
  
  /* Center puck */
  .lumelle-final-cta__wheel-center {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .lumelle-final-cta__wheel-center-puck {
    height: 2.5rem;
    width: 2.5rem;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.9);
    text-align: center;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: #55362A;
    box-shadow: 0 20px 60px rgba(251, 199, 178, 0.35);
    backdrop-filter: blur(4px);
  }
  
  /* CTA Button */
  .lumelle-final-cta__button {
    display: inline-flex;
    min-width: 200px;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background-color: #55362A;
    padding: 0.75rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #ffffff;
    box-shadow: 0 20px 60px rgba(251, 199, 178, 0.35);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
    border: none;
    cursor: pointer;
  }
  
  .lumelle-final-cta__button:hover {
    transform: translateY(-2px);
    box-shadow: 0 25px 70px rgba(251, 199, 178, 0.4);
  }
  
  .lumelle-final-cta__button-text {
    font-size: 0.75rem;
    color: rgba(85, 54, 42, 0.7);
    text-align: center;
    margin-top: 0.5rem;
  }
  
  /* Info card */
  .lumelle-final-cta__info-card {
    margin-top: 0.5rem;
    width: 100%;
    max-width: 28rem;
    border-radius: 1rem;
    background-color: rgba(255, 255, 255, 0.7);
    padding: 1rem;
    font-size: 0.875rem;
    color: rgba(85, 54, 42, 0.8);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
    text-align: left;
  }
  
  .lumelle-final-cta__info-card-title {
    font-weight: 600;
    color: #55362A;
  }
  
  .lumelle-final-cta__info-card-text {
    margin-top: 0.25rem;
    font-size: 0.75rem;
    color: rgba(85, 54, 42, 0.7);
  }
  
  .lumelle-final-cta__info-card-code {
    font-weight: 600;
  }
</style>

<section class="lumelle-final-cta">
  <div class="lumelle-final-cta__card">
    <div class="lumelle-final-cta__content">
      <h2 class="lumelle-final-cta__heading">{{ section.settings.heading }}</h2>
      
      <div class="lumelle-final-cta__wheel-container">
        <div class="lumelle-final-cta__wheel">
          <!-- Pointer -->
          <div class="lumelle-final-cta__wheel-pointer"></div>
          
          <!-- Wheel Body -->
          <div class="lumelle-final-cta__wheel-body">
            <div class="lumelle-final-cta__wheel-inner"></div>
            
            <!-- Static Labels positioned around the wheel -->
            <div class="lumelle-final-cta__wheel-labels">
              <span class="lumelle-final-cta__wheel-label" style="left: 68%; top: 12%;">5%</span>
              <span class="lumelle-final-cta__wheel-label" style="left: 90%; top: 32%;">10%</span>
              <span class="lumelle-final-cta__wheel-label" style="left: 92%; top: 60%;">10%</span>
              <span class="lumelle-final-cta__wheel-label" style="left: 76%; top: 86%;">15%</span>
              <span class="lumelle-final-cta__wheel-label" style="left: 50%; top: 96%;">5%</span>
              <span class="lumelle-final-cta__wheel-label" style="left: 24%; top: 86%;">10%</span>
              <span class="lumelle-final-cta__wheel-label" style="left: 8%; top: 60%;">10%</span>
              <span class="lumelle-final-cta__wheel-label" style="left: 10%; top: 32%;">5%</span>
            </div>
          </div>
          
          <!-- Center Puck -->
          <div class="lumelle-final-cta__wheel-center">
            <div class="lumelle-final-cta__wheel-center-puck"></div>
          </div>
        </div>
        
        <!-- CTA Button -->
        <a href="{{ section.settings.button_link }}" class="lumelle-final-cta__button">
          {{ section.settings.button_text }}
        </a>
        <p class="lumelle-final-cta__button-text">{{ section.settings.button_subtext }}</p>
      </div>
      
      <!-- Info Card -->
      <div class="lumelle-final-cta__info-card">
        <div class="lumelle-final-cta__info-card-title">{{ section.settings.info_title }}</div>
        <div class="lumelle-final-cta__info-card-text">
          {{ section.settings.info_text }} <span class="lumelle-final-cta__info-card-code">{{ section.settings.discount_code }}</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lumelle Final CTA",
  "tag": "section",
  "class": "lumelle-final-cta-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Spin the wheel to unlock your reward"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Reveal welcome deal"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "button_subtext",
      "label": "Button Subtext",
      "default": "Guaranteed welcome deal: Free Shipping on orders over £20+. Spin to reveal!"
    },
    {
      "type": "text",
      "id": "info_title",
      "label": "Info Card Title",
      "default": "Guaranteed welcome deal"
    },
    {
      "type": "text",
      "id": "info_text",
      "label": "Info Card Text",
      "default": "Use code"
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Discount Code",
      "default": "LUMELLE10"
    }
  ],
  "presets": [
    {
      "name": "Lumelle Final CTA"
    }
  ]
}
{% endschema %}
